---
import Layout from '../layouts/Layout.astro';

const videos = [
    {
        name: 'Metaverse Presentation',
        link: 'https://drive.google.com/file/d/1yUIEa3M5cF43dXAOP56qQdyhRmnrULjX'
    }
];
---

<Layout title="Metaverse Videos">
    <h1 class="mb-8 text-3xl font-bold">Project Videos</h1>

    <div class="overflow-x-auto">
        <table class="table w-full">
            <thead>
                <tr>
                    <th>Video Name</th>
                </tr>
            </thead>
            <tbody>
                {
                    videos.map((video) => (
                        <tr>
                            <td>{video.name}</td>
                            <td>
                                <a href={video.link} target="_blank" class="btn btn-sm">
                                    Open
                                </a>
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </table>
    </div>
</Layout>
