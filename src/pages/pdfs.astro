---
import Layout from '../layouts/Layout.astro';

const pdfs = [
    {
        name: 'Metaverse Research Paper',
        link: 'https://drive.google.com/file/d/14tq0gwg4XartGP1mOgudHkkXiWFlxI6K/view?usp=sharing'
    }
];
---

<Layout title="Metaverse PDFs">
    <h1 class="mb-8 text-3xl font-bold">Project Documents</h1>

    <div class="overflow-x-auto">
        <table class="table w-full">
            <thead>
                <tr>
                    <th>Document Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {
                    pdfs.map((pdf) => (
                        <tr>
                            <td>{pdf.name}</td>
                            <td>
                                <a href={pdf.link} target="_blank" class="btn btn-sm">
                                    Open
                                </a>
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </table>
    </div>
</Layout>
